# ──────────────────────────────────────────────
# AutoGestión360 — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ──────────────────────────────────────────────

# Servidor
PORT=4000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=tu_usuario_postgres
DB_PASSWORD=tu_password_postgres
DB_NAME=autogestion360

# Autenticación JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Email (Nodemailer — opcional para notificaciones)
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=correo@ejemplo.com
SMTP_PASS=tu_password_smtp
SMTP_FROM="AutoGestión360 <noreply@ejemplo.com>"

# Entorno
NODE_ENV=development
