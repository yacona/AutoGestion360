# AutoGestion360
# Copia este archivo a .env y ajusta los valores reales.

NODE_ENV=development
PORT=4000
TRUST_PROXY=false
REQUEST_BODY_LIMIT=256kb

DB_HOST=localhost
DB_PORT=5432
DB_USER=autogestion360
DB_PASSWORD=cambia_esta_clave
DB_NAME=autogestion360

JWT_SECRET=cambia_este_secreto_por_un_valor_largo_y_aleatorio
JWT_ISSUER=autogestion360
JWT_AUDIENCE=autogestion360-clients
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
SETUP_DEMO_PASSWORD=CambiaEstaClaveDemo123!
ALLOW_LEGACY_LICENSE_FALLBACK=false

# Lista separada por comas. Ajusta según frontend(s) autorizados.
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000
CORS_ALLOW_NO_ORIGIN=true
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_REFRESH_MAX=20
RATE_LIMIT_SETUP_DEMO_WINDOW_MS=3600000
RATE_LIMIT_SETUP_DEMO_MAX=3
RATE_LIMIT_REGISTRATION_WINDOW_MS=900000
RATE_LIMIT_REGISTRATION_MAX=10
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=60

SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=correo@ejemplo.com
SMTP_PASS=clave_smtp
