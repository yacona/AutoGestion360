# ──────────────────────────────────────────────────────────
# AutoGestión360 — Variables de entorno
#
# Copia este archivo:  cp .env.example .env
# NUNCA committees .env con valores reales.
# ──────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development        # development | production

# ── Base de datos PostgreSQL ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=tu_usuario_postgres
DB_PASSWORD=tu_password_postgres
DB_NAME=autogestion360

# Pool de conexiones (opcional — defaults de pg)
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=2000

# ── Autenticación JWT ─────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_al_menos_64_caracteres_aleatorios
JWT_EXPIRES_IN=8h           # Tiempo de expiración del token

# ── Email (Nodemailer) ────────────────────────────────────
# Necesario para: notificaciones de licencia, vencimientos, onboarding
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false           # true para port 465 (TLS), false para 587 (STARTTLS)
SMTP_USER=correo@ejemplo.com
SMTP_PASS=tu_password_smtp
SMTP_FROM="AutoGestión360 <noreply@ejemplo.com>"

# ── Uploads (multer) ──────────────────────────────────────
# Directorio base relativo a la raíz del proyecto
UPLOADS_DIR=uploads
# Tamaño máximo por archivo en bytes (5 MB por defecto)
# UPLOAD_MAX_FILE_SIZE=5242880

# ── CORS ──────────────────────────────────────────────────
# En producción, restringir a dominios reales separados por coma
# CORS_ORIGIN=https://app.autogestion360.com,https://www.autogestion360.com
# En desarrollo dejar vacío o usar *

# ── SaaS / Pasarela de pagos (futuro) ────────────────────
# WOMPI_PUBLIC_KEY=
# WOMPI_PRIVATE_KEY=
# WOMPI_EVENTS_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
